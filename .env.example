# Supabase (https://supabase.com/dashboard → proyecto → Connect o Settings → API Keys)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
# Una de las dos (la app acepta ambas):
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-jwt-legacy
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Clave service role (solo servidor; para cron de cambio de turno automático)
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Secreto para chamar ao cron de cambio de turno (p. ej. desde Vercel Cron)
CRON_SECRET=un-secreto-forte
